{
  "name": "sheet-magnet",
  "version": "0.1.0",
  "description": "Export your TTRPG character sheets to anything",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check:fast": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && biome check src/ && vitest run",
    "check": "pnpm check:fast && vitest run --coverage",
    "prepare": "husky",
    "deploy:prod": "pnpm build && node scripts/deploy.mjs",
    "foundry:release": "node scripts/release-foundry-module.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.56.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "svelte": "^5.0.0",
    "svelte-check": "^4.4.6",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "jsqr": "^1.4.0",
    "konva": "^9.3.0",
    "pdf-lib": "^1.17.1",
    "socket.io-client": "^4.8.3",
    "yaml": "^2.8.3"
  }
}
